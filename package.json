{
  "name": "terrorport-main",
  "version": "1.0.0",
  "description": "My personal portfolio website showcasing my web development projects, technical blog posts, and contact information.",
  "main": "index.js",
  "scripts": {
    "build:css": "npx tailwindcss -i ./css/input.css -o ./css/output.css --minify",
